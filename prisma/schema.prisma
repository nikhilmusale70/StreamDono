generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String
  passwordHash     String?          @map("password_hash")
  googleId         String?          @unique @map("google_id")
  emailVerified    DateTime?        @map("email_verified")
  image            String?
  subscriptionTier SubscriptionTier @default(FREE) @map("subscription_tier")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  donations        Donation[]
  config           StreamerConfig?

  @@map("users")
}

model StreamerConfig {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  donateSlug           String   @unique @map("donate_slug")
  streamlabsToken      String?  @map("streamlabs_token")
  minDonationAmount    Int      @default(10) @map("min_donation_amount")
  alertMessageTemplate String   @default("{name} donated ₹{amount}") @map("alert_message_template")
  overlayAnimation     String   @default("slide") @map("overlay_animation")
  overlaySoundUrl      String?  @map("overlay_sound_url")
  overlayDurationMs    Int      @default(5000) @map("overlay_duration_ms")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streamer_config")
}

model OrderMapping {
  id        String   @id @default(cuid())
  orderId   String   @unique @map("order_id")
  userId    String   @map("user_id")
  donorName String?  @map("donor_name")
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("order_mapping")
}

model Donation {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  razorpayPaymentId String         @unique @map("razorpay_payment_id")
  donorName         String?        @map("donor_name")
  donorEmail        String?        @map("donor_email")
  amount            Int
  currency          String         @default("INR")
  message           String?
  status            DonationStatus @default(CAPTURED)
  alertSent         Boolean        @default(false) @map("alert_sent")
  createdAt         DateTime       @default(now()) @map("created_at")
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("donations")
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum DonationStatus {
  CAPTURED
  FAILED
  REFUNDED
}
